code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled;

uniform vec4 Fire_Color : source_color;
uniform vec2 Speed;
uniform sampler2D tex_frg_3 : source_color;
uniform sampler2D tex_frg_5;



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = Fire_Color;


// Input:9
	float n_out9p0 = TIME;


// Vector2Parameter:11
	vec2 n_out11p0 = Speed;


// VectorOp:10
	vec2 n_out10p0 = vec2(n_out9p0) * n_out11p0;


// UVFunc:8
	vec2 n_in8p1 = vec2(1.00000, 1.00000);
	vec2 n_out8p0 = n_out10p0 * n_in8p1 + UV;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, n_out8p0);


// Texture2D:5
	vec4 n_out5p0 = texture(tex_frg_5, UV);


// FloatOp:6
	float n_out6p0 = n_out3p0.x - n_out5p0.x;


// Clamp:7
	float n_in7p1 = 0.00000;
	float n_in7p2 = 1.00000;
	float n_out7p0 = clamp(n_out6p0, n_in7p1, n_in7p2);


// Output:0
	ALBEDO = vec3(n_out2p0.xyz);
	ALPHA = n_out7p0;


}
