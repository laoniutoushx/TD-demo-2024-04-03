[resource]
code = "shader_type spatial;
render_mode blend_add, depth_draw_never, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, fog_disabled;

uniform vec2 MainTextureSpeed = vec2(1.000000, 1.000000);
uniform sampler2D MainTexture;
uniform float MainTexturePower = 1;



void fragment() {
// Input:4
	vec4 n_out4p0 = COLOR;


// Input:10
	float n_out10p0 = TIME;


// Vector2Parameter:12
	vec2 n_out12p0 = MainTextureSpeed;


// VectorOp:11
	vec2 n_out11p0 = vec2(n_out10p0) * n_out12p0;


// UVFunc:13
	vec2 n_in13p1 = vec2(1.00000, 1.00000);
	vec2 n_out13p0 = n_out11p0 * n_in13p1 + UV;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(MainTexture, n_out13p0);


// FloatParameter:8
	float n_out8p0 = MainTexturePower;


// FloatOp:7
	float n_out7p0 = pow(n_out3p0.x, n_out8p0);


// VectorOp:5
	vec4 n_out5p0 = n_out4p0 * vec4(n_out7p0);


// VectorDecompose:6
	float n_out6p0 = n_out5p0.x;
	float n_out6p1 = n_out5p0.y;
	float n_out6p2 = n_out5p0.z;
	float n_out6p3 = n_out5p0.w;


// Output:0
	ALBEDO = vec3(n_out5p0.xyz);
	ALPHA = n_out6p3;


}
"
