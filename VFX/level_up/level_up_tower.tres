code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled;

uniform vec2 Speed;
uniform sampler2D NoiseTexture : source_color;
uniform sampler2D tex_frg_13;



void fragment() {
// Input:12
	vec4 n_out12p0 = COLOR;


// Input:9
	float n_out9p0 = TIME;


// Vector2Parameter:10
	vec2 n_out10p0 = Speed;


// VectorOp:11
	vec2 n_out11p0 = vec2(n_out9p0) * n_out10p0;


// UVFunc:7
	vec2 n_in7p1 = vec2(1.00000, 1.00000);
	vec2 n_out7p0 = n_out11p0 * n_in7p1 + UV;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(NoiseTexture, n_out7p0);


// Texture2D:13
	vec4 n_out13p0 = texture(tex_frg_13, UV);


// VectorOp:15
	vec4 n_out15p0 = n_out3p0 * n_out13p0;


// VectorOp:16
	vec4 n_out16p0 = n_out12p0 * n_out15p0;
	float n_out16p4 = n_out16p0.a;


// Output:0
	ALBEDO = vec3(n_out16p0.xyz);
	ALPHA = n_out16p4;


}
"
