[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled;

uniform vec4 Color : source_color;
uniform bool Has_Multiply_Texture = false;
uniform vec2 Texture_Scale = vec2(1.000000, 1.000000);
uniform vec2 Texture_Speed = vec2(0.500000, 3.000000);
uniform sampler2D Aura_Texture : source_color;
uniform sampler2D tex_frg_3 : source_color;
uniform sampler2D Multiply_Texture : source_color;
uniform sampler2D depth_tex_frg_17 : hint_depth_texture;



void fragment() {
// ColorParameter:20
	vec4 n_out20p0 = Color;


// BooleanParameter:25
	bool n_out25p0 = Has_Multiply_Texture;


// Input:11
	vec4 n_out11p0 = COLOR;
	float n_out11p4 = n_out11p0.a;


// Vector2Parameter:9
	vec2 n_out9p0 = Texture_Scale;


// UVFunc:8
	vec2 n_in8p2 = vec2(0.00000, 0.00000);
	vec2 n_out8p0 = (UV - n_in8p2) * n_out9p0 + n_in8p2;


// Input:19
	vec4 n_out19p0 = COLOR;
	float n_out19p1 = n_out19p0.r;


// Vector2Parameter:7
	vec2 n_out7p0 = Texture_Speed;


// VectorOp:6
	vec2 n_out6p0 = vec2(n_out19p1) * n_out7p0;


// UVFunc:4
	vec2 n_in4p1 = vec2(1.00000, 1.00000);
	vec2 n_out4p0 = n_out6p0 * n_in4p1 + n_out8p0;


	vec4 n_out16p0;
// Texture2D:16
	n_out16p0 = texture(Aura_Texture, n_out4p0);
	float n_out16p1 = n_out16p0.r;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, UV);
	float n_out3p1 = n_out3p0.r;


// FloatOp:10
	float n_out10p0 = n_out16p1 * n_out3p1;


// FloatOp:12
	float n_out12p0 = n_out11p4 * n_out10p0;


	vec4 n_out23p0;
// Texture2D:23
	n_out23p0 = texture(Multiply_Texture, UV);
	float n_out23p1 = n_out23p0.r;


// FloatOp:21
	float n_out21p0 = n_out12p0 * n_out23p1;


	float n_out24p0;
// Switch:24
	n_out24p0 = mix(n_out12p0, n_out21p0, float(n_out25p0));


	float n_out17p0;
// ProximityFade:17
	float n_in17p0 = 0.10000;
	{
		float __depth_tex = texture(depth_tex_frg_17, SCREEN_UV).r;
		vec4 __depth_world_pos = INV_PROJECTION_MATRIX * vec4(SCREEN_UV * 2.0 - 1.0, __depth_tex, 1.0);
		__depth_world_pos.xyz /= __depth_world_pos.w;
		n_out17p0 = clamp(1.0 - smoothstep(__depth_world_pos.z + n_in17p0, __depth_world_pos.z, VERTEX.z), 0.0, 1.0);
	}


// FloatOp:18
	float n_out18p0 = n_out24p0 * n_out17p0;


// Output:0
	ALBEDO = vec3(n_out20p0.xyz);
	ALPHA = n_out18p0;


}
"
