code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled, fog_disabled;

uniform vec4 ColorParameter : source_color;
uniform float Alpha : hint_range(0.0, 1.0) = 1.0;
uniform float Fresnel_power = 1.0;



void fragment() {
// ColorParameter:4
	vec4 n_out4p0 = ColorParameter;
	float n_out4p4 = n_out4p0.a;


// FloatParameter:6
	float n_out6p0 = Alpha;


// FloatParameter:3
	float n_out3p0 = Fresnel_power;


// Fresnel:2
	float n_out2p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_out3p0);


// FloatOp:5
	float n_out5p0 = n_out4p4 * n_out2p0;


// FloatOp:7
	float n_out7p0 = n_out6p0 * n_out5p0;


// Output:0
	ALBEDO = vec3(n_out4p0.xyz);
	ALPHA = n_out7p0;


}
"
