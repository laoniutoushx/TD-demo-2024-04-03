code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, ambient_light_disabled, fog_disabled;

uniform float Intensity = 1;
uniform vec2 Scale = vec2(1.000000, 1.000000);
uniform vec2 Velocity = vec2(0.000000, 0.000000);
uniform sampler2D Texture : source_color, repeat_enable;
uniform sampler2D Multiply_Texture : source_color, filter_linear;
uniform sampler2D Gradient_1D_texture : source_color, filter_linear, repeat_disable;
uniform bool Use_Particles_Alpha = true;
uniform float VAnishing : hint_range(0, 1);



void vertex() {
// GetBillboardMatrix:2
	// Node is disabled and code is not generated.
}

void fragment() {
// FloatParameter:42
	float n_out42p0 = Intensity;


// Vector2Parameter:16
	vec2 n_out16p0 = Scale;


// UVFunc:15
	vec2 n_in15p2 = vec2(0.00000, 0.00000);
	vec2 n_out15p0 = (UV - n_in15p2) * n_out16p0 + n_in15p2;


// Input:32
	float n_out32p0 = TIME;


// Vector2Parameter:34
	vec2 n_out34p0 = Velocity;


// VectorOp:33
	vec2 n_out33p0 = vec2(n_out32p0) * n_out34p0;


// UVFunc:31
	vec2 n_in31p1 = vec2(1.00000, 1.00000);
	vec2 n_out31p0 = n_out33p0 * n_in31p1 + n_out15p0;


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = texture(Texture, n_out31p0);
	float n_out10p1 = n_out10p0.r;


	vec4 n_out27p0;
// Texture2D:27
	n_out27p0 = texture(Multiply_Texture, UV);
	float n_out27p1 = n_out27p0.r;


// FloatOp:28
	float n_out28p0 = n_out10p1 - n_out27p1;


// Clamp:35
	float n_in35p1 = 0.00000;
	float n_in35p2 = 1.00000;
	float n_out35p0 = clamp(n_out28p0, n_in35p1, n_in35p2);


	vec4 n_out18p0;
// Texture2D:18
	n_out18p0 = texture(Gradient_1D_texture, vec2(n_out35p0));
	float n_out18p4 = n_out18p0.a;


// VectorOp:41
	vec3 n_out41p0 = vec3(n_out42p0) * vec3(n_out18p0.xyz);


// BooleanParameter:39
	bool n_out39p0 = Use_Particles_Alpha;


// Input:36
	vec4 n_out36p0 = COLOR;
	float n_out36p4 = n_out36p0.a;


// FloatParameter:40
	float n_out40p0 = VAnishing;


	float n_out38p0;
// Switch:38
	n_out38p0 = mix(n_out40p0, n_out36p4, float(n_out39p0));


// FloatOp:37
	float n_out37p0 = n_out18p4 * n_out38p0;


// Output:0
	ALBEDO = n_out41p0;
	ALPHA = n_out37p0;


}
