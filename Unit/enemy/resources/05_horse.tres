[resource]
script = ExtResource("3_762rs")
clz_name = "05_horse"
model_path = ExtResource("2_ybep3")
title = "老马"
desc = "老马曾是丛林部落中重要的驮运工具和伙伴。它身强体壮，温顺可靠，与部落居民建立了深厚的感情。然而，诅咒降临时，老马也未能幸免。它的身躯变得异常巨大，肌肉扭曲隆起，覆盖着坚硬的骨质甲壳。曾经温和的眼神被狂暴所取代，取而代之的是充满怒火的血红色瞳孔。它不再听从任何指令，只是凭借着残存的领地意识，横冲直撞地破坏着一切闯入其视野的事物。蹄声如雷，所过之处，树木倾倒，大地颤抖。"
