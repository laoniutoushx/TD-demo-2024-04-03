[resource]
script = ExtResource("3_h476a")
clz_name = "04_dog"
model_path = ExtResource("2_0v5or")
title = "老狗"
desc = "老狗并非丛林中原生的野兽，而是一只曾经陪伴某个在丛林深处隐居的古老部落的忠实犬只。部落遭遇诅咒时，这只老狗也未能幸免。然而，与部落成员彻底腐化为帕吉不同，老狗的诅咒更加扭曲和缓慢。它失去了大部分的血肉，只剩下嶙峋的骨架和少量干枯的皮毛，但它的生命力却异常顽强，对曾经守护的领地有着近乎病态的执念。它在丛林的阴影中徘徊，发出令人毛骨悚然的呜咽，任何靠近部落废墟的生物都会被它视为入侵者，遭到无情的攻击。"
