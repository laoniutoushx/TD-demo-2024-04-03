[resource]
script = ExtResource("3_rf7fr")
clz_name = "armabee_evolved"
model_path = ExtResource("2_oxydl")
title = " 高级装甲蜂"
desc = "最初的装甲蜂是蜂巢意志为了适应战场环境而改造的生物兵器。它们坚硬的甲壳和锋利的螫针让它们成为战场上令人畏惧的存在。然而，随着战争的升级，敌人也变得越来越强大，蜂巢意志不得不对装甲蜂进行进一步的改造和进化。高级装甲蜂就是装甲蜂的进化形态。它们不仅拥有更强大的防御力和攻击力，还获得了新的能力。一些高级装甲蜂甚至可以释放电磁脉冲，干扰敌人的电子设备，或者喷射腐蚀性液体，对敌人造成持续伤害。它们是蜂巢意志空中力量的中坚力量，是敌人不可忽视的威胁。"
