[resource]
script = ExtResource("2_gquih")
clz_name = "03_pug"
model_path = ExtResource("2_ki07y")
title = "帕吉"
desc = "在古老的丛林深处，流传着关于一个被诅咒的部落的传说。这个部落曾与自然和谐共处，但他们逐渐沉迷于一种黑暗的仪式，试图获取丛林深处隐藏的强大力量。他们的贪婪触怒了丛林中的古老灵体。作为惩罚，整个部落都被一种可怕的诅咒吞噬。他们的肉体开始腐烂、肿胀，与丛林中的藤蔓和真菌融为一体，最终变成了名为“帕吉”的恐怖怪物。帕吉的每一次移动都伴随着腐败的气息和令人不安的低语，那是被诅咒的灵魂在痛苦地哀嚎。它漫无目的地在丛林中游荡，攻击所有胆敢闯入其领地的生物，仿佛在发泄永恒的痛苦和憎恨。"
