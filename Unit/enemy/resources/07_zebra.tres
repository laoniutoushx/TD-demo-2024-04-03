[resource]
script = ExtResource("3_rf7fr")
clz_name = "07_zebra"
model_path = ExtResource("2_mkm6v")
title = "斑马"
desc = "这片丛林并非一直如此充满诅咒和危险。在很久以前，这里曾是各种生灵和平共处的天堂，其中就包括一群拥有独特黑白条纹的斑马。它们以其敏捷的身姿和群体行动而闻名。然而，当诅咒蔓延，扭曲了丛林中的一切时，这些斑马也受到了影响。它们的条纹变得更加扭曲和混乱，仿佛流动的黑暗能量，而原本温顺的性格则被一种焦躁和破坏欲所取代。它们不再成群结队，而是各自为战，带着一种莫名的愤怒冲击着任何阻碍它们前进的事物。"
