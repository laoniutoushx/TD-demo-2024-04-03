		float __input_range = n_in10p2 - n_in10p1;
		float __output_range = n_in10p4 - n_in10p3;
		n_out10p0 = n_in10p3 + __output_range * ((n_out9p1 - n_in10p1) / __input_range);
	}


// Input:4
