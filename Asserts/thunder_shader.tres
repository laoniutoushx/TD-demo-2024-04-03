void fragment() {
// Texture2D:11
	vec4 n_out11p0 = texture(tex_frg_11, UV);


// Input:9
	vec4 n_out9p0 = COLOR;
	float n_out9p1 = n_out9p0.r;


	float n_out10p0;
// Remap:10
	float n_in10p1 = 0.00000;
	float n_in10p2 = 1.00000;
	float n_in10p3 = 0.00000;
	float n_in10p4 = 0.80000;
