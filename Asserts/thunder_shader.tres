// VectorOp:7
	vec2 n_in7p1 = vec2(0.00000, -0.50000);
	vec2 n_out7p0 = vec2(n_out4p0) * n_in7p1;


// UVFunc:3
	vec2 n_in3p1 = vec2(1.00000, 1.00000);
	vec2 n_out3p0 = n_out7p0 * n_in3p1 + UV;


// Texture2D:2
