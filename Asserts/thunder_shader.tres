	float n_out2p1 = n_out2p0.r;


// SmoothStep:8
	float n_in8p1 = 0.80000;
	float n_out8p0 = smoothstep(n_out10p0, n_in8p1, n_out2p1);


// Output:0
	ALBEDO = vec3(n_out11p0.xyz);
	ALPHA = n_out8p0;


}
