	vec2 n_out4p0 = n_out7p0 * n_in4p1 + UV;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(NoiseTexture, n_out4p0);


// Texture2D:12
	vec4 n_out12p0 = texture(tex_frg_12, UV);


// VectorOp:10
	vec4 n_out10p0 = n_out3p0 * n_out12p0;


// VectorOp:11
	vec4 n_out11p0 = n_out13p0 * n_out10p0;
	float n_out11p4 = n_out11p0.a;


// Output:0
	ALBEDO = vec3(n_out11p0.xyz);
	ALPHA = n_out11p4;


}
