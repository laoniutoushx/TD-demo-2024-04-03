code = "shader_type spatial;
render_mode blend_add, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded, shadows_disabled, fog_disabled;

uniform vec4 ColorParameter : source_color;
uniform vec2 Speed;
uniform sampler2D NoiseTexture : source_color;
uniform sampler2D tex_frg_12;



void fragment() {
// ColorParameter:13
	vec4 n_out13p0 = ColorParameter;


// Input:5
	float n_out5p0 = TIME;


// Vector2Parameter:6
	vec2 n_out6p0 = Speed;


// VectorOp:7
	vec2 n_out7p0 = vec2(n_out5p0) * n_out6p0;


// UVFunc:4
