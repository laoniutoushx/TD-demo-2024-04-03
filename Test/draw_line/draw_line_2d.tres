code = "shader_type canvas_item;
render_mode blend_add, unshaded;

uniform sampler2D Texture2DParameter : repeat_enable;
uniform vec4 ColorParameter : source_color;



void fragment() {
// Input:10
	float n_out10p0 = TIME;


// VectorOp:11
	vec2 n_in11p1 = vec2(1.00000, 0.00000);
	vec2 n_out11p0 = vec2(n_out10p0) * n_in11p1;


// UVFunc:9
	vec2 n_in9p1 = vec2(1.00000, 1.00000);
	vec2 n_out9p0 = n_out11p0 * n_in9p1 + UV;


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Texture2DParameter, n_out9p0);
	float n_out8p4 = n_out8p0.a;


// ColorParameter:13
	vec4 n_out13p0 = ColorParameter;


// VectorOp:12
	vec3 n_out12p0 = vec3(n_out8p0.xyz) * vec3(n_out13p0.xyz);


// Output:0
	COLOR.rgb = n_out12p0;
	COLOR.a = n_out8p4;


}
"
